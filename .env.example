# Demo mode: mock data, no API calls (defaults to true when unset)
VITE_DEMO_MODE=true

# RAWG API key (games) — https://rawg.io/apidocs — free tier, account required
VITE_RAWG_API_KEY=

# Google Calendar OAuth — https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=

# Optional CORS proxy — e.g. https://api.allorigins.win/raw?url=
VITE_CORS_PROXY=

# Optional RSSHub instance for Nautiljon — e.g. https://rsshub.app
VITE_RSSHUB_BASE=
