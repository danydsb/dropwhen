# Demo mode: mock data, no API calls (set to true to preview without keys)
VITE_DEMO_MODE=false

# IGDB credentials (server-side only, NEVER prefixed by VITE_)
# Local dev: put them in .env.local
# Vercel: Project Settings -> Environment Variables
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Comics FR : proxy /api/urban-comics-proxy (Edge Function Vercel en prod, middleware Vite en dev)

# Optional CORS proxy (utilise surtout les sources comics externes)
# VITE_CORS_PROXY=
