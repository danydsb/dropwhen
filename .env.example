# Demo mode: mock data, no API calls (set to true to preview without keys)
VITE_DEMO_MODE=false

# RAWG API key (games) — https://rawg.io/apidocs — free tier, account required
VITE_RAWG_API_KEY=

# Optional Jikan base URL — default: https://api.jikan.moe/v4
# VITE_JIKAN_BASE=https://api.jikan.moe/v4

# Optional CORS proxy — e.g. https://api.allorigins.win/raw?url=
VITE_CORS_PROXY=
